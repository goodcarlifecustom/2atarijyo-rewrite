# WordPress REST API
WP_USERNAME=your-wp-login-username
WP_APPLICATION_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# WordPressがサブディレクトリにある場合だけ指定
# 例:
# WP_REST_ROOT=https://www.atarijo.com/media/wp-json/
WP_REST_ROOT=

# 通常は posts,pages でOK。カスタム投稿タイプがあるなら追加
WP_POST_TYPES=posts,pages

# rendered = 実際に表示されるHTML
# raw = Gutenbergの編集元に近い本文。返ってこない環境ではrenderedにフォールバック
WP_CONTENT_MODE=rendered

# 短すぎるHTMLをエラーにする閾値
MIN_HTML_LENGTH=500
